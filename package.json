{
  "name": "metro-dashboard",
  "version": "2.5.0",
  "description": "Metro Access Control - Doorking Operations Dashboard",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.metroaccess.dashboard",
    "productName": "Metro Dashboard",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "index.html",
      "contacts.html",
      "manuals.html",
      "style.css",
      "script.js",
      "main.js",
      "preload.js",
      "config.json",
      "assets/**",
      "manuals/**"
    ],
    "asarUnpack": [
      "manuals/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "Westingo",
      "repo": "metro-dashboard",
      "releaseType": "release"
    }
  },
  "keywords": [],
  "author": "Metro Access Control",
  "license": "ISC",
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
